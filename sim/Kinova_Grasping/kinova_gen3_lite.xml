<mujoco model="gen3_lite">

  <compiler angle="radian" meshdir="assets"/>

  <option integrator="implicitfast"/>

  <default>
    <default class="visual">
      <geom type="mesh" contype="0" conaffinity="0" group="2" rgba="0.75294 0.75294 0.75294 1"/>
    </default>
    <default class="collision">
      <geom type="mesh" group="3"/>
    </default>
    <default class="large_actuator">
      <position kp="800" kv="40" forcerange="-14 14"/>
    </default>
    <default class="small_actuator">
      <position kp="300" kv="20" forcerange="-7 7"/>
    </default>
    
      <!-- gripper actuator class -->
    <default class="gripper_actuator">
      <position kp="20" kv="2" forcerange="-50 50"/>
    </default>
    <site size="0.001" rgba="0.5 0.5 0.5 0.3" group="4"/>
  </default>

  <asset>
    <mesh name="base_link" content_type="model/stl" file="base_link.STL"/>
    <mesh name="shoulder_link" content_type="model/stl" file="shoulder_link.STL"/>
    <mesh name="arm_link" content_type="model/stl" file="arm_link.STL"/>
    <mesh name="forearm_link" content_type="model/stl" file="forearm_link.STL"/>
    <mesh name="lower_wrist_link" content_type="model/stl" file="lower_wrist_link.STL"/>
    <mesh name="upper_wrist_link" content_type="model/stl" file="upper_wrist_link.STL"/>
    <mesh name="gripper_base_link" content_type="model/stl" file="gripper_base_link.STL"/>
    <mesh name="right_finger_prox_link" content_type="model/stl" file="right_finger_prox_link.STL"/>
    <mesh name="right_finger_dist_link" content_type="model/stl" file="right_finger_dist_link.STL"/>
    <mesh name="left_finger_prox_link" content_type="model/stl" file="left_finger_prox_link.STL"/>
    <mesh name="left_finger_dist_link" content_type="model/stl" file="left_finger_dist_link.STL"/>
  </asset>

  <worldbody>
    <body name="base_link" pos="0 0 0">
      <geom type="mesh" mesh="base_link"/>
      <body name="SHOULDER" pos="0 0 0.12825">
        <inertial pos="2.477e-05 0.0221353 0.0993769" quat="0.972429 0.233194 -0.000430944 0.00108761" mass="0.959744" diaginertia="0.00165947 0.00158128 0.000717195"/>
        <joint name="J0" pos="0 0 0" axis="0 0 1" range="-2.76 2.76" />
        <geom type="mesh" mesh="shoulder_link"/>
        <body name="ARM" pos="0 -0.03 0.115" quat="0.707105 0.707108 0 0">
          <inertial pos="0.029983 0.211548 0.0453031" quat="0.534676 0.467794 -0.46336 0.529706" mass="1.17756" diaginertia="0.0115237 0.0114928 0.000839712"/>
          <joint name="J1" pos="0 0 0" axis="0 0 1" range="-2.76 2.76" />
          <geom type="mesh" mesh="arm_link"/>
          <body name="FOREARM" pos="0 0.28 0" quat="-3.67321e-06 -1 0 0">
            <inertial pos="0.0301559 0.0950221 0.0073555" quat="0.523543 0.49139 -0.473675 0.50997" mass="0.597677" diaginertia="0.00169754 0.00163253 0.000291376"/>
            <joint name="J2" pos="0 0 0" axis="0 0 1" range="-2.76 2.76" />
            <geom type="mesh" mesh="forearm_link"/>
            <body name="LOWER_WRIST" pos="0 -0.14 0.02" quat="0.707105 0.707108 0 0">
              <inertial pos="0.00575149 0.0100044 0.0871921" quat="0.700403 -0.13124 -0.134345 0.688595" mass="0.526934" diaginertia="0.000785199 0.000756398 0.000275722"/>
              <joint name="J3" pos="0 0 0" axis="0 0 1" range="-2.67 2.67" />
              <geom type="mesh" mesh="lower_wrist_link"/>
              <body name="UPPER_WRIST" pos="0.0285 0 0.105" quat="0.707105 0 0.707108 0">
                <inertial pos="0.0805652 0.00980409 0.018728" quat="0.00431726 0.708285 -4.18922e-06 0.705913" mass="0.580973" diaginertia="0.00108466 0.00106374 0.000212638"/>
                <joint name="J4" pos="0 0 0" axis="0 0 1" range="-2.67 2.67" />
                <geom type="mesh" mesh="upper_wrist_link"/>
                <body name="END_EFFECTOR" pos="-0.105 0 0.0285" quat="0.707105 0 -0.707108 0">
                  <joint name="J5" pos="0 0 0" axis="0 0 1" range="-2.67 2.67" />
                  <geom type="mesh" mesh="gripper_base_link"/>
                  <site name="END_EFFECTOR_SITE" pos="0 0 0.13" quat="0.7071 0 0 0.7071" size="0.002" rgba="1 0 0 1" group="0"/>
                  <body name="RIGHT_FINGER_PROX" pos="0 -0.030501 0.070003" quat="0.707105 0 0.707108 0">
                    <inertial pos="0.020257 0.0063483 6.991e-05" quat="0.598941 0.598941 0.375858 0.375858" mass="0.018385" diaginertia="5.25068e-06 4.77e-06 1.59932e-06"/>
                    <joint name="RIGHT_BOTTOM" pos="0 0 0" axis="0 0 1" range="-0.09 0.96" />
                    <geom name="RIGHT_FINGER_PROX_GEOM" type="mesh" mesh="right_finger_prox_link"/>
                    <body name="RIGHT_FINGER_DIST" pos="-0.045636 0.020423 0">
                      <inertial pos="0.018488 0.0011091 0" quat="0.557345 0.557345 0.435162 0.435162" mass="0.010748" diaginertia="1.91e-06 1.61e-06 5.5e-07"/>
                      <joint name="RIGHT_TIP" pos="0 0 0" axis="0 0 1" range="-1.03 0.21" />
                      <geom name="RIGHT_FINGER_DIST_GEOM" type="mesh" mesh="right_finger_dist_link" friction="0.7 0.15 0.2"/>
                    </body>
                  </body>
                  <body name="LEFT_FINGER_PROX" pos="0 0.0305 0.070003" quat="0.707105 0 0.707108 0">
                    <inertial pos="0.020257 0.0063483 6.99e-05" quat="0.598941 0.598941 0.375858 0.375858" mass="0.018385" diaginertia="5.25068e-06 4.77e-06 1.59932e-06"/>
                    <joint name="LEFT_BOTTOM" pos="0 0 0" axis="0 0 1" range="-0.96 0.09" />
                    <geom name="LEFT_FINGER_PROX_GEOM" type="mesh" mesh="left_finger_prox_link"/>
                    <body name="LEFT_FINGER_DIST" pos="-0.045636 -0.020423 6.9901e-05">
                      <inertial pos="-0.018488 0.0011091 0" quat="0.557345 0.557345 0.435162 0.435162" mass="0.010748" diaginertia="1.91e-06 1.61e-06 5.5e-07"/>
                      <joint name="LEFT_TIP" pos="0 0 0" axis="0 0 1" range="-0.21 1.03" />
                      <geom name="LEFT_FINGER_DIST_GEOM" type="mesh" mesh="left_finger_dist_link" friction="0.7 0.15 0.2"/>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <!-- Arm joints (J0-J5) -->
    <position class="large_actuator" name="J0" joint="J0" ctrlrange="-2.76 2.76"/>
    <position class="large_actuator" name="J1" joint="J1" ctrlrange="-2.76 2.76"/>
    <position class="large_actuator" name="J2" joint="J2" ctrlrange="-2.76 2.76"/>
    <position class="small_actuator" name="J3" joint="J3" ctrlrange="-2.67 2.67"/>
    <position class="small_actuator" name="J4" joint="J4" ctrlrange="-2.67 2.67"/>
    <position class="small_actuator" name="J5" joint="J5" ctrlrange="-2.67 2.67"/>
    
    <!-- Gripper joints -->
    <position class="gripper_actuator" name="RIGHT_BOTTOM" joint="RIGHT_BOTTOM" ctrlrange="-0.09 0.96"/>
    <position class="gripper_actuator" name="RIGHT_TIP" joint="RIGHT_TIP" ctrlrange="-1.03 0.21"/>
    <position class="gripper_actuator" name="LEFT_BOTTOM" joint="LEFT_BOTTOM" ctrlrange="-0.96 0.09"/>
    <position class="gripper_actuator" name="LEFT_TIP" joint="LEFT_TIP" ctrlrange="-0.21 1.03"/>
  </actuator>

  
  
</mujoco>
